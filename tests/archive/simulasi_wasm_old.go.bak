// 5. Querier
func (m *MockBank) SearchAccount(address string) (map[string]interface{}, bool) { return nil, false }
func (m *MockBank) GetAllBalances() map[string]map[string]uint64               { return nil }
func (m *MockBank) LoadAllAccountsFromDB() int                                 { return 0 }
func (m *MockBank) GetPublicKeyFromLedger(bc *types.Blockchain, address string) string { return "" }


type MockBVM struct {
        bank *MockBank
}

