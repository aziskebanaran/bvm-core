func main() {
	os.RemoveAll("./data/test_db")
	store, _ := storage.NewLevelDBStore("./data/test_db")
	wasmK := keeper.NewKeeper(store)

	// --- 1. SUNTIK MULTI-TOKEN (STATE AWAL) ---
	addrSultan := "SULTAN_HOKI_88"
	addrReseller := "RESELLER_SETIA"

	// Saldo awal Sultan: 5000 BVM (Native) dan 1000 GOLD (Token)
	store.Put("a:"+addrSultan, uint64(5000))
	store.Put("t:GOLD:"+addrSultan, uint64(1000)) 

	fmt.Printf("💰 [STATE] Sultan: 5000 BVM, 1000 GOLD | Reseller: 0 GOLD\n")

	mockBank := &MockBank{store: store}
	mockBVM := &MockBVM{bank: mockBank}
	wasmK.SetBVM(mockBVM)

// --- 2. SINKRONISASI SDK (READ FROM FILE) ---
fmt.Println("🔍 Membaca Kontrak dari Hasil Pabrik (Makefile)...")

// Kita deklarasikan bytecode dan errRead sekaligus
bytecode, errRead := os.ReadFile("contracts/test_contract/contract.wasm")
if errRead != nil {
    fmt.Printf("❌ Gagal membaca file WASM: %v\n", errRead)
    return
}

fmt.Printf("✅ Kontrak Dimuat! Ukuran: %d bytes\n", len(bytecode))


	// --- 3. EKSEKUSI KONTRAK ---
	addrContract, _ := wasmK.DeployContract("transfer_service", bytecode)
	fmt.Println("⏳ Smart Contract: Memproses pengiriman 500 GOLD ke Reseller...")

	// Kita kirim payload alamat pengirim sebagai pemicu
	err := wasmK.ExecuteContract(addrContract, "transfer_service", []byte(addrSultan))

	if err != nil {
		fmt.Printf("❌ Error Eksekusi: %v\n", err)
	} else {
		// --- 4. VERIFIKASI AKHIR (BUKTI NYATA) ---
		// Kita cek langsung ke database/mockBank apakah saldo sudah berpindah
		finalSultan := mockBank.GetBalance(addrSultan, "GOLD")
		finalReseller := mockBank.GetBalance(addrReseller, "GOLD")

		fmt.Printf("\n📊 --- LAPORAN KEUANGAN BVM ---\n")
		fmt.Printf("👑 Sultan GOLD   : %d\n", finalSultan)
		fmt.Printf("🤝 Reseller GOLD : %d\n", finalReseller)

		if finalReseller == 500 {
			fmt.Println("\n✅ STATUS: TRANSFER MULTI-TOKEN BERHASIL!")
		}
	}
}
