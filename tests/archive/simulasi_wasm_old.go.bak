// --- MOCK SYSTEM (Versi Mirror Sempurna) ---
type MockBank struct {
    store storage.BVMStore
}

// 1. Keeper (Core) - SEKARANG SUDAH BISA MENULIS KE DISK
func (m *MockBank) GetAccount(addr string) (types.Account, error) { return types.Account{}, nil }
func (m *MockBank) SaveAccount(acc *types.Account) error          { return nil }

func (m *MockBank) GetBalance(addr string, symbol string) uint64 {
    var key string
    if symbol == "BVM" || symbol == "" {
        key = "a:" + addr
    } else {
        key = "t:" + symbol + ":" + addr
    }
    var bal uint64
    _ = m.store.Get(key, &bal)
    return bal
}

func (m *MockBank) AddBalance(addr string, amount uint64, symbol string) {
    current := m.GetBalance(addr, symbol)
    key := "t:" + symbol + ":" + addr
    if symbol == "BVM" || symbol == "" { key = "a:" + addr }
    _ = m.store.Put(key, current + amount)
}

func (m *MockBank) SubBalance(addr string, amount uint64, symbol string) error {
    current := m.GetBalance(addr, symbol)
    if current < amount {
        return fmt.Errorf("🚨 Saldo tidak cukup")
    }
    key := "t:" + symbol + ":" + addr
    if symbol == "BVM" || symbol == "" { key = "a:" + addr }
    return m.store.Put(key, current - amount)
}

// --- TAMBAHKAN METODE MINT & BURN KE MOCKBANK ---

func (m *MockBank) Mint(addr string, amount uint64, symbol string) {
    if symbol == "BVM" || symbol == "" { return }
    current := m.GetBalance(addr, symbol)
    key := "t:" + symbol + ":" + addr
    _ = m.store.Put(key, current + amount)
}

func (m *MockBank) Burn(addr string, amount uint64, symbol string) error {
    if symbol == "BVM" || symbol == "" { return nil }
    current := m.GetBalance(addr, symbol)
    if current < amount {
        return fmt.Errorf("🚨 Saldo %s tidak cukup untuk burn", symbol)
    }
    key := "t:" + symbol + ":" + addr
    return m.store.Put(key, current - amount)
}


// 2. In
func (m *MockBank) HoldForMempool(tx types.Transaction) error      { return nil }
func (m *MockBank) ReleaseFromMempool(tx types.Transaction)        {}
func (m *MockBank) ValidateSend(tx types.Transaction) error        { return nil }
func (m *MockBank) GetOrCreateAccount(addr string) *types.Account  { return &types.Account{} }
func (m *MockBank) IsFrozen(symbol string) bool                    { return false }

// 3. Out
func (m *MockBank) Transfer(tx types.Transaction) error            { return nil }
func (m *MockBank) FinalizeTransaction(tx types.Transaction, minerAddr string, params *types.Params) {}
func (m *MockBank) CreateToken(owner string, symbol string, mintFee uint64) error {
    return nil
}
// Di dalam MockBank Sultan
func (m *MockBank) GetTokenMetadata(symbol string) (banktypes.TokenMetadata, bool) {
    // Kita buat metadata palsu agar simulasi lancar
    return banktypes.TokenMetadata{
        Symbol: symbol, 
        Owner: "SULTAN_HOKI_88",
        MintFee: 10,
    }, true
}

func (m *MockBank) SetTokenMetadata(md banktypes.TokenMetadata) error {
    return nil
}


// 4. Audit & Admin
func (m *MockBank) CheckSupplyIntegrity(symbol string)             {}
func (m *MockBank) CalculateBalanceManual(bc *types.Blockchain, addr string, symbol string) uint64 { return 0 }
func (m *MockBank) FreezeToken(caller string, symbol string) error   { return nil }
func (m *MockBank) UnfreezeToken(caller string, symbol string) error { return nil }
